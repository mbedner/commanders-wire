---
// ─── PWA Install Prompt ───────────────────────────────────────────────────────
// Slim footer banner with two install buttons (Remix Icons).
//   • "iPhone / iPad" → opens modal with Safari share-sheet instructions
//   • "Install App"   → triggers BeforeInstallPromptEvent (Android/Chrome)
// Hidden entirely in standalone (PWA) mode or after dismiss (180 days).
// Force-show for testing: add ?install to the URL.
---

<!-- ── Banner ──────────────────────────────────────────────────────────────── -->
<div id="install-prompt" class="ip" aria-live="polite" hidden>
  <span class="ip-label">Get the app</span>
  <div class="ip-actions">
    <button class="ip-btn ip-btn--ios" id="ip-ios-btn" type="button">
      <!-- ri-apple-fill -->
      <svg class="ip-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M11.6734 7.22198C10.7974 7.22198 9.44138 6.22598 8.01338 6.26198C6.12938 6.28598 4.40138 7.35397 3.42938 9.04597C1.47338 12.442 2.92538 17.458 4.83338 20.218C5.76938 21.562 6.87338 23.074 8.33738 23.026C9.74138 22.966 10.2694 22.114 11.9734 22.114C13.6654 22.114 14.1454 23.026 15.6334 22.99C17.1454 22.966 18.1054 21.622 19.0294 20.266C20.0974 18.706 20.5414 17.194 20.5654 17.11C20.5294 17.098 17.6254 15.982 17.5894 12.622C17.5654 9.81397 19.8814 8.46998 19.9894 8.40998C18.6694 6.47798 16.6414 6.26198 15.9334 6.21398C14.0854 6.06998 12.5374 7.22198 11.6734 7.22198ZM14.7934 4.38998C15.5734 3.45398 16.0894 2.14598 15.9454 0.849976C14.8294 0.897976 13.4854 1.59398 12.6814 2.52998C11.9614 3.35798 11.3374 4.68998 11.5054 5.96198C12.7414 6.05798 14.0134 5.32598 14.7934 4.38998Z"/></svg>
      iPhone / iPad
    </button>
    <button class="ip-btn ip-btn--android" id="ip-android-btn" type="button" hidden>
      <!-- ri-android-line -->
      <svg class="ip-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M19 13H5V20H19V13ZM19 11C19 7.13401 15.866 4 12 4C8.13401 4 5 7.13401 5 11H19ZM6.38231 3.9681C7.92199 2.73647 9.87499 2 12 2C14.125 2 16.078 2.73647 17.6177 3.9681L19.0711 2.51472L20.4853 3.92893L19.0319 5.38231C20.2635 6.92199 21 8.87499 21 11V21C21 21.5523 20.5523 22 20 22H4C3.44772 22 3 21.5523 3 21V11C3 8.87499 3.73647 6.92199 4.9681 5.38231L3.51472 3.92893L4.92893 2.51472L6.38231 3.9681ZM9 9C8.44772 9 8 8.55228 8 8C8 7.44772 8.44772 7 9 7C9.55228 7 10 7.44772 10 8C10 8.55228 9.55228 9 9 9ZM15 9C14.4477 9 14 8.55228 14 8C14 7.44772 14.4477 7 15 7C15.5523 7 16 7.44772 16 8C16 8.55228 15.5523 9 15 9Z"/></svg>
      Install App
    </button>
  </div>
  <button class="ip-dismiss" id="ip-dismiss-btn" type="button" aria-label="Dismiss install prompt">✕</button>
</div>

<!-- ── iOS Modal ──────────────────────────────────────────────────────────── -->
<div id="ip-modal" class="ip-modal" role="dialog" aria-modal="true" aria-labelledby="ip-modal-title" hidden>
  <div class="ip-modal-backdrop" id="ip-modal-backdrop"></div>
  <div class="ip-modal-card">
    <button class="ip-modal-close" id="ip-modal-close" type="button" aria-label="Close">✕</button>
    <strong class="ip-modal-title" id="ip-modal-title">Add to Home Screen</strong>
    <p class="ip-modal-sub">Follow these steps in Safari:</p>
    <ol class="ip-modal-steps">
      <li>
        Tap the <strong>Share</strong> button
        <!-- ri-upload-2-line (iOS share sheet icon) -->
        <span class="ip-share-icon" aria-label="share icon">
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4 19H20V12H22V20C22 20.5523 21.5523 21 21 21H3C2.44772 21 2 20.5523 2 20V12H4V19ZM13 9V16H11V9H6L12 3L18 9H13Z"/></svg>
        </span>
        at the bottom of your screen
      </li>
      <li>Scroll down and tap <strong>"Add to Home Screen"</strong></li>
      <li>Tap <strong>Add</strong> in the top-right corner — done!</li>
    </ol>
  </div>
</div>

<style>
  /* ── Banner ──────────────────────────────────────────────────────────────── */
  .ip {
    width: 100%;
    background: #1a1a1a;
    border-top: 1px solid #333;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    flex-shrink: 0;
  }

  .ip-label {
    font-size: 13px;
    font-weight: 700;
    color: #e8e8e8;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ip-actions {
    display: flex;
    align-items: center;
    gap: 8px;
    flex: 1;
  }

  .ip-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 12px;
    font-weight: 700;
    border-radius: 5px;
    padding: 6px 13px;
    transition: opacity 0.15s;
    white-space: nowrap;
    line-height: 1;
  }
  .ip-btn:hover { opacity: 0.85; }

  .ip-btn--ios {
    background: #f0f0f0;
    color: #111111;
  }
  .ip-btn--android {
    background: #9b1535;
    color: #ffffff;
  }

  .ip-icon {
    width: 13px;
    height: 13px;
    fill: currentColor;
    flex-shrink: 0;
  }

  .ip-dismiss {
    background: transparent;
    border: none;
    color: #b0b0b0;
    font-size: 15px;
    cursor: pointer;
    padding: 4px 6px;
    line-height: 1;
    flex-shrink: 0;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .ip-dismiss:hover { color: #e8e8e8; }

  /* ── Modal ───────────────────────────────────────────────────────────────── */
  .ip-modal {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .ip-modal[hidden] { display: none; }

  .ip-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(2px);
  }

  .ip-modal-card {
    position: relative;
    z-index: 1;
    background: #1e1e1e;
    border: 1px solid #333;
    border-radius: 12px 12px 0 0;
    padding: 24px 20px 32px;
    width: 100%;
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    animation: ip-slide-up 0.28s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes ip-slide-up {
    from { transform: translateY(100%); opacity: 0; }
    to   { transform: translateY(0);    opacity: 1; }
  }

  .ip-modal-close {
    position: absolute;
    top: 14px;
    right: 16px;
    background: transparent;
    border: none;
    color: #b0b0b0;
    font-size: 16px;
    cursor: pointer;
    padding: 4px 8px;
    line-height: 1;
    border-radius: 4px;
    transition: color 0.15s;
  }
  .ip-modal-close:hover { color: #e8e8e8; }

  .ip-modal-title {
    font-size: 16px;
    font-weight: 800;
    color: #f0f0f0;
    line-height: 1.2;
  }

  .ip-modal-sub {
    margin: 0;
    font-size: 13px;
    color: #b0b0b0;
  }

  .ip-modal-steps {
    margin: 4px 0 0;
    padding-left: 20px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    font-size: 14px;
    color: #cccccc;
    line-height: 1.5;
  }
  .ip-modal-steps strong { color: #f0f0f0; }

  .ip-share-icon {
    display: inline-flex;
    align-items: center;
    vertical-align: middle;
    color: #3478f6;
    margin: 0 2px;
  }
  .ip-share-icon svg {
    width: 15px;
    height: 15px;
    fill: currentColor;
  }
</style>

<script>
  (() => {
    const STORAGE_KEY  = 'bf-install-v2';
    const DISMISS_DAYS = 180;

    const banner = document.getElementById('install-prompt');
    const modal  = document.getElementById('ip-modal');
    if (!banner || !modal) return;

    // Never show inside the installed PWA
    const isStandalone = matchMedia('(display-mode: standalone)').matches
                      || navigator.standalone === true;
    if (isStandalone) return;

    // Check for ?install param to force-show (testing)
    const forceShow = new URLSearchParams(location.search).has('install');

    // Dismissed recently — skip (unless forced)
    if (!forceShow) {
      const dismissed = localStorage.getItem(STORAGE_KEY);
      if (dismissed && Date.now() - parseInt(dismissed, 10) < DISMISS_DAYS * 864e5) return;
    }

    // ── Dismiss helpers ──────────────────────────────────────────────────────
    function dismissBanner() {
      localStorage.setItem(STORAGE_KEY, String(Date.now()));
      banner.hidden = true;
    }

    function closeModal() {
      modal.hidden = true;
    }

    document.getElementById('ip-dismiss-btn')?.addEventListener('click', dismissBanner);
    document.getElementById('ip-modal-close')?.addEventListener('click', closeModal);
    document.getElementById('ip-modal-backdrop')?.addEventListener('click', closeModal);

    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    // ── iOS button → open modal ──────────────────────────────────────────────
    document.getElementById('ip-ios-btn')?.addEventListener('click', () => {
      modal.hidden = false;
    });

    // ── Android: intercept BeforeInstallPromptEvent ──────────────────────────
    let deferredPrompt = null;
    const androidBtn   = document.getElementById('ip-android-btn');

    window.addEventListener('beforeinstallprompt', e => {
      e.preventDefault();
      deferredPrompt = e;
      if (androidBtn) androidBtn.hidden = false;
      banner.hidden = false;
    });

    androidBtn?.addEventListener('click', async () => {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      const { outcome } = await deferredPrompt.userChoice;
      deferredPrompt = null;
      if (outcome === 'accepted') banner.hidden = true;
    });

    window.addEventListener('appinstalled', () => { banner.hidden = true; });

    // ── iOS Safari — show banner ─────────────────────────────────────────────
    const isIos    = /iphone|ipad|ipod/i.test(navigator.userAgent);
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);

    if (isIos && isSafari) {
      banner.hidden = false;
    }
  })();
</script>
