---
interface Props { lastUpdated: string | null; }
const { lastUpdated } = Astro.props;
---

<header class="mast">
  <div class="mast-inner">
    <div class="mast-left">
      <a href="/" class="mast-wordmark">
        <span class="mast-w1">BURGUNDY</span><span class="mast-w2">FEED</span>
      </a>
      <span class="mast-tagline">Washington's hourly newswire</span>
    </div>

    <div class="mast-right">
      <div class="mast-sync">
        <span class="sync-dot"></span>
        <span class="sync-label" id="syncLabel" data-iso={lastUpdated ?? ''}>
          {lastUpdated ? 'Updated —' : 'Not yet synced'}
        </span>
      </div>

    </div>
  </div>
</header>

<script>
  // ── Format the "Updated" timestamp in the browser's local timezone ──────────
  const label = document.getElementById('syncLabel');
  if (label) {
    const iso = label.getAttribute('data-iso');
    if (iso) {
      const d = new Date(iso);
      if (!isNaN(d.getTime())) {
        const formatted = d.toLocaleTimeString('en-US', {
          hour: 'numeric', minute: '2-digit', hour12: true, timeZoneName: 'short',
        });
        label.textContent = `Updated ${formatted}`;
      }
    }
  }

</script>

<style>
  .mast {
    position: relative;
    z-index: 200;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    box-shadow: var(--shadow);
    transition: background 0.2s, border-color 0.2s;
  }
  .mast-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 16px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }

  /* ── Wordmark ── */
  .mast-left {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-shrink: 0;
  }
  .mast-wordmark {
    display: flex;
    align-items: baseline;
    gap: 0;
    text-decoration: none;
  }
  .mast-w1 {
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--text);
    line-height: 1;
  }
  .mast-w2 {
    font-size: 15px;
    font-weight: 900;
    letter-spacing: 0.04em;
    color: var(--accent);
    line-height: 1;
  }
  .mast-tagline {
    display: none;
    font-size: 10px;
    font-weight: 400;
    color: var(--text-3);
    letter-spacing: 0.02em;
    white-space: nowrap;
  }
  @media (min-width: 500px) { .mast-tagline { display: block; } }

  /* ── Right side ── */
  .mast-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .mast-sync {
    display: flex;
    align-items: center;
    gap: 5px;
  }
  .sync-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--live-dot);
    flex-shrink: 0;
    animation: blink 2.5s ease-in-out infinite;
  }
  .sync-label {
    font-size: 11px;
    color: var(--text-3);
    white-space: nowrap;
    display: none;
  }
  @media (min-width: 420px) {
    .sync-label { display: block; }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0.25; }
  }

</style>
