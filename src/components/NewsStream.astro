---
import type { Article } from '../lib/types';
import StoryItem from './StoryItem.astro';
interface Props { items: Article[]; }
const { items } = Astro.props;

const INITIAL_COUNT = 20;
const hiddenCount   = Math.max(0, items.length - INITIAL_COUNT);
let rank = 1;
---

<div id="filter-banner" class="filter-banner" hidden>
  <span class="filter-banner-label">Showing: <strong id="filter-banner-tag"></strong></span>
  <button class="filter-banner-clear" id="filter-banner-clear" type="button" aria-label="Clear filter">✕ clear</button>
</div>

<div class="stream stream-capped" id="news-stream">
  {items.map(item => <StoryItem item={item} rank={rank++} />)}
</div>

{hiddenCount > 0 && (
  <button class="see-more-btn" id="see-more-btn" type="button">
    See {hiddenCount} more {hiddenCount === 1 ? 'story' : 'stories'}
  </button>
)}

<style>
  /* ── Filter banner ───────────────────────────────────────────────────────── */
  .filter-banner {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 12px;
    margin-bottom: 2px;
    background: var(--surface-2);
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 13px;
  }
  .filter-banner[hidden] { display: none; }
  .filter-banner-label {
    flex: 1;
    color: var(--text-3);
  }
  .filter-banner-label strong {
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .filter-banner-clear {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-4);
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 3px 8px;
    cursor: pointer;
    font-family: inherit;
    transition: color 0.12s, border-color 0.12s;
    white-space: nowrap;
  }
  .filter-banner-clear:hover {
    color: var(--text);
    border-color: var(--border-strong);
  }

  /* ── Stream ──────────────────────────────────────────────────────────────── */
  .stream { padding-bottom: 8px; }

  /* Cap: hide articles past the 20th */
  .stream-capped > :global(article:nth-child(n+21)) { display: none; }

  /* ── See More button ─────────────────────────────────────────────────────── */
  .see-more-btn {
    display: block;
    width: 100%;
    padding: 11px 0;
    margin: 4px 0 16px;
    background: transparent;
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text-3);
    font-size: 13px;
    font-weight: 700;
    font-family: inherit;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition: color 0.12s, border-color 0.12s, background 0.12s;
  }
  .see-more-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--surface-2);
  }
  .see-more-btn[hidden] { display: none; }
</style>

<script>
  (() => {
    const stream      = document.getElementById('news-stream');
    const banner      = document.getElementById('filter-banner');
    const bannerTag   = document.getElementById('filter-banner-tag');
    const bannerClear = document.getElementById('filter-banner-clear');
    const seeMoreBtn  = document.getElementById('see-more-btn');
    if (!stream || !banner || !bannerTag || !bannerClear) return;

    let activeTag = null;
    let isCapped  = stream.classList.contains('stream-capped');

    function uncap() {
      isCapped = false;
      stream.classList.remove('stream-capped');
      if (seeMoreBtn) seeMoreBtn.hidden = true;
    }

    function applyFilter(tag) {
      activeTag = tag;

      if (tag) {
        bannerTag.textContent = tag;
        banner.hidden = false;
        // Auto-expand so all matching articles are visible
        stream.classList.remove('stream-capped');
        if (seeMoreBtn) seeMoreBtn.hidden = true;
      } else {
        banner.hidden = true;
        // Restore cap only if the user hasn't manually expanded
        if (isCapped) {
          stream.classList.add('stream-capped');
          if (seeMoreBtn) seeMoreBtn.hidden = false;
        }
      }

      // Show/hide individual articles
      stream.querySelectorAll('article[data-tags]').forEach(art => {
        const tags = art.dataset.tags ? art.dataset.tags.split(',') : [];
        art.hidden = !!tag && !tags.includes(tag);
      });

      // Scroll to top of Latest News when a filter is applied
      if (tag) {
        const section = document.getElementById('stream');
        if (section) {
          const navH = document.querySelector('nav, header, .nav, .masthead')?.offsetHeight ?? 56;
          const top  = section.getBoundingClientRect().top + window.scrollY - navH - 8;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      }
    }

    // Tag pill clicks
    stream.addEventListener('click', e => {
      const btn = e.target.closest('[data-filter-tag]');
      if (!btn) return;
      e.preventDefault();
      applyFilter(activeTag === btn.dataset.filterTag ? null : btn.dataset.filterTag);
    });

    // Clear filter
    bannerClear.addEventListener('click', () => applyFilter(null));

    // See More
    if (seeMoreBtn) {
      seeMoreBtn.addEventListener('click', uncap);
    }
  })();
</script>
