---

{hasItems && (
  <section class="rivals">
    <p class="rivals-label">Around the NFC East</p>
    {TEAMS.map(({ key, label, bg, svg }) => {
      const teamItems = items.filter(i => i.team === key);
      if (!teamItems.length) return null;
      return (
        <div class="rivals-team">
          <p class="rivals-eyebrow">{label}</p>
          {teamItems.map(item => (
            <a href={item.url} target="_blank" rel="noopener noreferrer" class="rival-card">
              <div class="rival-card-body">
                <p class="rival-hed">{item.headline}</p>
                <span class="rival-time">{rel(item.publishedAt)}</span>
              </div>
              {item.imageUrl
                ? <img class="rival-thumb" src={item.imageUrl} alt="" loading="lazy" decoding="async" />
                : <div class="rival-fallback" style={`background:${bg}`} aria-hidden="true">
                    <Fragment set:html={svg} />
                  </div>
              }
            </a>
          ))}
        </div>
      );
    })}
  </section>
)}

<style>
  .rivals {
    padding-top: 4px;
    padding-bottom: 16px;
  }

  .rivals-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #d4940e;
    padding: 14px 0 10px;
    border-top: 1px solid var(--border);
    margin-top: 4px;
  }

  .rivals-team {
    margin-bottom: 14px;
  }

  /* Plain gray uppercase eyebrow — like a section label */
  .rivals-eyebrow {
    font-size: 10px;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-4);
    margin: 0 0 6px;
  }

  .rival-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
    text-decoration: none;
  }
  .rival-card:last-child { border-bottom: none; }
  .rival-card:hover .rival-hed { color: var(--accent); }

  .rival-card-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .rival-hed {
    font-size: 15px;
    font-weight: 600;
    color: var(--text-2);
    line-height: 1.4;
    margin: 0;
    word-break: break-word;
    transition: color 0.12s;
  }

  .rival-time {
    font-size: 11px;
    font-weight: 600;
    color: var(--text-4);
    white-space: nowrap;
  }

  /* Image thumbnail */
  .rival-thumb {
    width: 88px;
    height: 62px;
    object-fit: cover;
    border-radius: 5px;
    flex-shrink: 0;
  }

  /* SVG fallback — team-color background, logo centered */
  .rival-fallback {
    width: 88px;
    height: 62px;
    border-radius: 5px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .rival-fallback svg {
    width: 46px;
    height: 46px;
  }
</style>
