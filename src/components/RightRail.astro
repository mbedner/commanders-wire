---
import TeamDates          from './TeamDates.astro';
import Schedule           from './Schedule.astro';
import TeamStats          from './TeamStats.astro';
import TransactionTracker from './TransactionTracker.astro';
import type { EspnTransaction } from '../lib/espn';

interface Props {
  dates:       any;
  schedule:    any;
  lastSeason:  any;
  stats:       any;
  players:     any;
  txItems?:    EspnTransaction[];
  txLabel?:    string;
  showTx?:     boolean;
}

const { dates, schedule, lastSeason, stats, players,
        txItems = [], txLabel = '', showTx = false } = Astro.props;
---

<div class="rail">
  {showTx && txItems.length > 0 && (
    <div class="rail-section" id="transactions">
      <TransactionTracker items={txItems} label={txLabel} />
    </div>
  )}
  <div class="rail-section" id="rail-schedule">
    <Schedule schedule={schedule} lastSeason={lastSeason} />
  </div>
  <div class="rail-section">
    <TeamStats stats={stats} players={players} />
  </div>
  <div class="rail-section">
    <TeamDates dates={dates} />
  </div>
</div>

<style>
  .rail {
    position: sticky;
    top: 56px;
    padding-top: 8px;
    padding-bottom: 32px;
    align-self: start;
  }
  .rail-section + .rail-section {
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }
</style>
