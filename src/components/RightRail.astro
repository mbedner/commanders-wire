---
import TeamDates from './TeamDates.astro';
import Schedule  from './Schedule.astro';
import TeamStats from './TeamStats.astro';

const { dates, schedule, stats, players } = Astro.props;
---

<div class="rail">
  <Schedule schedule={schedule} />
  <div class="rail-sep"></div>
  <TeamStats stats={stats} players={players} />
  <div class="rail-sep"></div>
  <TeamDates dates={dates} />
</div>

<style>
  .rail {
    position: sticky;
    top: 56px;
    padding-top: 8px;
    padding-bottom: 32px;
    align-self: start;
  }
  .rail-sep {
    height: 1px;
    background: var(--border);
    margin: 14px 0;
  }
</style>
