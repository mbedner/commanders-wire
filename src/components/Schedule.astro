---
import type { UPCOMING_SCHEDULE, LAST_SEASON } from '../config/schedule';
interface Props {
  schedule:   typeof UPCOMING_SCHEDULE;
  lastSeason: typeof LAST_SEASON;
}
const { schedule, lastSeason } = Astro.props;

const DIVISION_OPPONENTS = new Set([
  'Dallas Cowboys', 'NY Giants', 'Philadelphia Eagles',
]);

function scheduleSort(games: typeof schedule) {
  const scored = games
    .filter(g => g.opponent !== 'TBD' && g.home !== null)
    .map(g => ({
      ...g,
      _group: g.home
        ? (DIVISION_OPPONENTS.has(g.opponent) ? 0 : 1)   // home div, home non-div
        : (DIVISION_OPPONENTS.has(g.opponent) ? 2 : 3),  // away div, away non-div
    }));
  return scored.sort((a, b) => a._group - b._group);
}

const sortedSchedule = scheduleSort(schedule);
---

<div class="module">
  <div class="module-hd">
    2026 Opponents
    <span class="sched-pending">Schedule releases May 2026</span>
  </div>

  <div class="sched-list">
    {sortedSchedule.map((g, i) => {
      const prevGroup = i > 0 ? sortedSchedule[i - 1]._group : g._group;
      const showDivider = i > 0 && g._group !== prevGroup;
      return (
        <>
          {showDivider && <div class="sched-divider"/>}
          <div class="sched-row">
            <span class="sched-ha">{g.home ? 'vs' : '@'}</span>
            <span class="sched-opp">{g.opponent}</span>
          </div>
        </>
      );
    })}
  </div>

  <!-- 2025 Season Results -->
  <div class="season-hd">
    <span class="season-yr">{lastSeason.year} Season</span>
    <span class="season-rec">{lastSeason.record}</span>
  </div>

  <div class="results-list">
    {lastSeason.games.map(g => (
      <div class="result-row">
        <span class="res-wk">{g.week}</span>
        <span class="res-ha">{g.home === null ? '' : g.home ? 'vs' : '@'}</span>
        <span class="res-opp">{g.opponent}</span>
        {g.result !== '—' ? (
          <span class="res-score">{g.ws}–{g.os}</span>
        ) : (
          <span class="res-score res-bye">BYE</span>
        )}
        <span class={`res-tag res-tag--${g.result.toLowerCase()}`}>{g.result}</span>
      </div>
    ))}
  </div>
</div>

<style>
  .module-hd {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 10px;
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 6px;
    flex-wrap: wrap;
  }
  .sched-pending {
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0;
    text-transform: none;
    color: var(--text-4);
    font-style: italic;
  }

  .sched-list { display: flex; flex-direction: column; margin-bottom: 4px; }
  .sched-divider { height: 4px; }
  .sched-row {
    display: grid;
    grid-template-columns: 24px 1fr;
    gap: 6px;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
  }
  .sched-ha  { color: var(--text-3); font-size: 11px; }
  .sched-opp { color: var(--text); font-weight: 600; }

  /* ── 2025 Results ──────────────────────────────────────────────────────── */
  .season-hd {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: 6px 0;
    margin-top: 16px;
  }
  .season-yr {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .season-rec {
    font-size: 13px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .results-list { display: flex; flex-direction: column; }
  .result-row {
    display: grid;
    grid-template-columns: 28px 18px 1fr auto 20px;
    gap: 3px;
    align-items: center;
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
    font-size: 11px;
  }
  .res-wk    { font-size: 10px; font-weight: 700; color: var(--text-4); }
  .res-ha    { color: var(--text-3); font-size: 10px; }
  .res-opp   { color: var(--text-2); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .res-score { color: var(--text-3); text-align: right; white-space: nowrap; font-variant-numeric: tabular-nums; }
  .res-bye   { color: var(--text-4); font-style: italic; }

  .res-tag {
    font-size: 9px;
    font-weight: 800;
    text-align: center;
    border-radius: 2px;
    padding: 1px 3px;
    letter-spacing: 0.04em;
  }
  .res-tag--w { color: #22c55e; }
  .res-tag--l { color: var(--text-4); }
  .res-tag--— { color: var(--text-4); }
</style>
