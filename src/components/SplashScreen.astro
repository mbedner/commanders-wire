---
// ─── Splash Screen ────────────────────────────────────────────────────────────
// Animation sequence (all CSS-driven, no JS required for timing):
//
//  Phase 1 — Stripes drop in from top, staggered:
//    • Center gold stripe leads (dramatic ease)
//    • Outer white stripes follow slightly behind
//
//  Phase 2 — Pattern splits at center:
//    • Left group (white-left + gold-left-half) exits left
//    • Right group (gold-right-half + white-right) exits right
//    • "BURGUNDY FEED" name fades in as panels depart
//
//  Phase 3 — JS fades out the whole splash after MIN_MS
//
//  Modes differ in speed and background intensity:
//    everyday  → calm, deliberate (default)
//    draft     → slightly faster, warmer
//    gameday   → fast, aggressive ease with spring overshoot on drop-in

export type SplashMode = 'everyday' | 'draft' | 'gameday';
interface Props { mode: SplashMode; }
const { mode } = Astro.props;
---

<div id="splash" class={`sp sp--${mode}`} aria-hidden="true" role="presentation" hidden>

  <!-- Site name revealed after the curtain splits -->
  <div class="sp-reveal">
    <p class="sp-name">
      <span class="sp-n1">BURGUNDY</span><span class="sp-n2">FEED</span>
    </p>
    {mode === 'draft' && (
      <span class="sp-badge sp-badge--draft">DRAFT COVERAGE</span>
    )}
    {mode === 'gameday' && (
      <span class="sp-badge sp-badge--gameday">
        <span class="sp-dot"></span>GAME DAY
      </span>
    )}
  </div>

  <!--
    Two curtain groups. Each is full-screen (position: absolute; inset: 0)
    and contains only the stripe elements assigned to its exit direction.
    The gold stripe is split in half between the two groups so the center
    seam tears exactly on the screen midline.
  -->

  <!-- Left group → exits translateX(-100vw) -->
  <div class="sp-group sp-group--l">
    <div class="sp-st sp-st--wl"></div>
    <div class="sp-st sp-st--gl"></div>
  </div>

  <!-- Right group → exits translateX(+100vw) -->
  <div class="sp-group sp-group--r">
    <div class="sp-st sp-st--gr"></div>
    <div class="sp-st sp-st--wr"></div>
  </div>

</div>

<style>
  /* ── Splash container ─────────────────────────────────────────────────────── */
  .sp {
    position: fixed;
    inset: 0;
    z-index: 9999;
    overflow: hidden;           /* clips stripes sliding from above */
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sp-bg);
    opacity: 1;
    transition: opacity 0.4s ease;
  }

  /* Background per mode — progressively deeper/more intense */
  .sp--everyday { --sp-bg: #5a1414; }
  .sp--draft    { --sp-bg: #4a1010; }
  .sp--gameday  { --sp-bg: #380808; }

  /* JS adds this class to trigger the overall fade-out */
  .sp.sp--exit {
    opacity: 0;
    pointer-events: none;
  }

  /* ── Site name (revealed behind the departing curtains) ──────────────────── */
  .sp-reveal {
    position: relative;
    z-index: 1;                 /* below the stripe groups (z-index: 2) */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    opacity: 0;
    animation: sp-reveal 0.5s ease var(--sp-reveal-t) both;
  }

  .sp--everyday { --sp-reveal-t: 0.88s; }
  .sp--draft    { --sp-reveal-t: 0.78s; }
  .sp--gameday  { --sp-reveal-t: 0.65s; }

  @keyframes sp-reveal {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: translateY(0);   }
  }

  .sp-name {
    margin: 0;
    font-family: 'Inter', 'Arial Black', sans-serif;
    font-size: clamp(24px, 6.5vw, 40px);
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1;
    white-space: nowrap;
  }
  .sp-n1 { color: #ffffff; }
  .sp-n2 { color: #d4940e; }

  /* ── Mode badges ──────────────────────────────────────────────────────────── */
  .sp-badge {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }
  .sp-badge--draft   { color: #d4940e; }
  .sp-badge--gameday { color: #ff5555; }

  .sp-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: currentColor;
    flex-shrink: 0;
    animation: dot-pulse 0.85s ease-in-out infinite alternate;
  }
  @keyframes dot-pulse {
    to { opacity: 0.25; transform: scale(0.65); }
  }

  /* ── Stripe groups ────────────────────────────────────────────────────────── */
  .sp-group {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
  }

  /* ── Phase 1: stripes drop from top ──────────────────────────────────────── */
  @keyframes sp-drop {
    from { transform: translateY(-100vh); }
    to   { transform: translateY(0); }
  }

  /* Gold (center) leads — both halves animate identically */
  .sp--everyday .sp-st--gl,
  .sp--everyday .sp-st--gr {
    animation: sp-drop 0.58s cubic-bezier(0.16, 1, 0.3, 1) 0.06s both;
  }
  .sp--everyday .sp-st--wl,
  .sp--everyday .sp-st--wr {
    animation: sp-drop 0.58s cubic-bezier(0.16, 1, 0.3, 1) 0.24s both;
  }

  .sp--draft .sp-st--gl,
  .sp--draft .sp-st--gr {
    animation: sp-drop 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.04s both;
  }
  .sp--draft .sp-st--wl,
  .sp--draft .sp-st--wr {
    animation: sp-drop 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.19s both;
  }

  /* Game Day: spring overshoot (cubic-bezier above y=1) for snap/energy */
  .sp--gameday .sp-st--gl,
  .sp--gameday .sp-st--gr {
    animation: sp-drop 0.42s cubic-bezier(0.2, 1.5, 0.4, 1) 0.03s both;
  }
  .sp--gameday .sp-st--wl,
  .sp--gameday .sp-st--wr {
    animation: sp-drop 0.42s cubic-bezier(0.2, 1.5, 0.4, 1) 0.14s both;
  }

  /* ── Phase 2: curtain split exit ─────────────────────────────────────────── */
  @keyframes sp-exit-l { to { transform: translateX(-100vw); } }
  @keyframes sp-exit-r { to { transform: translateX( 100vw); } }

  .sp--everyday .sp-group--l { animation: sp-exit-l 0.52s cubic-bezier(0.4, 0, 1, 1) 0.88s both; }
  .sp--everyday .sp-group--r { animation: sp-exit-r 0.52s cubic-bezier(0.4, 0, 1, 1) 0.88s both; }

  .sp--draft .sp-group--l    { animation: sp-exit-l 0.46s cubic-bezier(0.4, 0, 1, 1) 0.78s both; }
  .sp--draft .sp-group--r    { animation: sp-exit-r 0.46s cubic-bezier(0.4, 0, 1, 1) 0.78s both; }

  /* Game Day: aggressive acceleration out */
  .sp--gameday .sp-group--l  { animation: sp-exit-l 0.38s cubic-bezier(0.6, 0, 1, 0.8) 0.62s both; }
  .sp--gameday .sp-group--r  { animation: sp-exit-r 0.38s cubic-bezier(0.6, 0, 1, 0.8) 0.62s both; }

  /* ── Individual stripes ───────────────────────────────────────────────────── */
  /*
    Stripe positions are relative to the viewport center (50%).
    Pattern mirrors the favicon: white · gold · white, thin-wide-thin.
    Gold is split at 50% so each half belongs to its curtain group.

    Widths:  white = 26px each, gold = 20px per half (40px total)
    Spacing: 70px gap from gold edge to white inner edge
  */
  .sp-st {
    position: absolute;
    top: 0;
    bottom: 0;
    /* Start off-screen so there is no flash before animation-fill-mode:both
       applies the `from` keyframe state on the first painted frame. */
    transform: translateY(-100vh);
  }

  /*
    Widths:  white = 26px each, gold = 56px total (28px per half)
    Gap:     24px between gold outer edge and white inner edge
  */
  .sp-st--wl { left: calc(50% - 78px); width: 26px; background: #ffffff; }
  .sp-st--gl { left: calc(50% - 28px); width: 28px; background: #d4940e; }
  .sp-st--gr { left: 50%;              width: 28px; background: #d4940e; }
  .sp-st--wr { left: calc(50% + 52px); width: 26px; background: #ffffff; }
</style>

<script>
  (() => {
    const splash = document.getElementById('splash');
    if (!splash) return;

    const params      = new URLSearchParams(location.search);
    const isStandalone = matchMedia('(display-mode: standalone)').matches
                      || (navigator as any).standalone === true;
    const forceSplash  = params.has('splash');

    // Only show in standalone mode or when forced with ?splash
    if (!isStandalone && !forceSplash) {
      splash.remove();
      return;
    }

    // In standalone: only show on first launch per session
    // sessionStorage clears when the PWA is fully closed, so this fires on
    // each fresh app open but not on internal navigations or auto-reloads.
    if (isStandalone && !forceSplash) {
      if (sessionStorage.getItem('bf-launched')) {
        splash.remove();
        return;
      }
      sessionStorage.setItem('bf-launched', '1');
    }

    // We've confirmed we should show — unhide now (starts hidden to prevent
    // a flash on normal browser visits before JS has a chance to remove it).
    splash.hidden = false;

    // Hold until page is loaded + minimum display time
    // (prevents the animation being cut short on cache-fast loads)
    const MIN_MS = 2200;
    const t0 = performance.now();

    function dismiss() {
      const wait = Math.max(0, MIN_MS - (performance.now() - t0));
      setTimeout(() => {
        splash.classList.add('sp--exit');
        splash.addEventListener('transitionend', () => splash.remove(), { once: true });
      }, wait);
    }

    if (document.readyState === 'complete') dismiss();
    else window.addEventListener('load', dismiss, { once: true });
  })();
</script>
