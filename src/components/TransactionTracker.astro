---
import type { EspnTransaction } from '../lib/espn';

interface Props {
  items:  EspnTransaction[];
  label:  string;
  days?:  number;   // how many days back to show (default 30)
}

const { items, label, days = 30 } = Astro.props;

// Filter to the requested window and types we care about
const SHOW_TYPES = new Set(['signing', 'release', 'trade']);
const cutoff = Date.now() - days * 24 * 60 * 60 * 1000;

const visible = items.filter(t =>
  SHOW_TYPES.has(t.type) &&
  new Date(t.date).getTime() >= cutoff,
);

function rel(iso: string): string {
  const m = Math.floor((Date.now() - new Date(iso).getTime()) / 60000);
  if (m < 60)  return `${m}m ago`;
  const h = Math.floor(m / 60);
  if (h < 24)  return `${h}h ago`;
  const d = Math.floor(h / 24);
  return `${d}d ago`;
}

const BADGE: Record<string, string> = {
  signing: 'SIGNED',
  trade:   'TRADE',
  release: 'RELEASED',
};
---

{visible.length > 0 && (
  <div class="module" id="transactions">
    <div class="tx-hd">
      <div class="tx-hd-left">
        <span class="tx-title">Transactions</span>
      </div>
      <span class="tx-label">{label}</span>
    </div>

    <div class="tx-list">
      {visible.map(t => (
        <div class={`tx-row tx-row--${t.type}`}>
          <div class="tx-top">
            <span class={`tx-badge tx-badge--${t.type}`}>{BADGE[t.type]}</span>
            <span class="tx-time">{rel(t.date)}</span>
          </div>
          <p class="tx-desc">{t.description}</p>
        </div>
      ))}
    </div>
  </div>
)}

<style>
  /* ── Header ── */
  .tx-hd {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .tx-hd-left {
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tx-title {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
  }
  .tx-label {
    font-size: 9px;
    font-weight: 500;
    color: var(--text-4);
    letter-spacing: 0.04em;
    font-style: italic;
  }

  /* ── Rows ── */
  .tx-list {
    display: flex;
    flex-direction: column;
  }
  .tx-row {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 0;
    border-bottom: 1px solid var(--border);
  }
  .tx-row:last-child { border-bottom: none; }

  /* ── Top row: badge + time ── */
  .tx-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .tx-badge {
    font-size: 9px;
    font-weight: 800;
    letter-spacing: 0.08em;
    padding: 2px 6px;
    border-radius: 3px;
  }
  /* Signing — gold */
  .tx-badge--signing {
    background: #fff8e8;
    color: #a86e08;
    border: 1px solid #d4a030;
  }
  /* Trade — burgundy */
  .tx-badge--trade {
    background: #fdf0f3;
    color: #b03050;
    border: 1px solid #c06080;
  }
  /* Release — neutral */
  .tx-badge--release {
    background: var(--surface-2);
    color: var(--text-3);
    border: 1px solid var(--border-strong);
  }
  :root[data-theme="dark"] .tx-badge--signing {
    background: #1a1200;
    color: #d4a030;
    border-color: #8a6010;
  }
  :root[data-theme="dark"] .tx-badge--trade {
    background: #1f0810;
    color: #d06080;
    border-color: #7a2040;
  }

  .tx-time {
    font-size: 10px;
    color: var(--text-4);
    white-space: nowrap;
  }

  /* ── Description ── */
  .tx-desc {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-2);
    line-height: 1.45;
  }
</style>
