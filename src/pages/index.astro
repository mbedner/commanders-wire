// ── LIVE DATA ────────────────────────────────────────────────────────────────
let data: StoredData = { articles: [], breaking: [], lastRun: null };
let liveStats: LiveStats | null = null;
let espnTransactions: EspnTransaction[] = [];
try {
  const runtime = (Astro.locals as any).runtime;
  const kv: KVNamespace | undefined =
    runtime?.env?.ARTICLES_KV ??
    (Astro.locals as any).ARTICLES_KV;
  console.log('[cw] runtime present:', !!runtime, '| kv bound:', !!kv);
  if (kv) {
    const [allData, statsRaw, txRaw] = await Promise.all([
      readAll(kv),
      kv.get('stats:snapshot'),
      kv.get('transactions:latest'),
    ]);
    data = allData;
    if (statsRaw) liveStats = JSON.parse(statsRaw) as LiveStats;
    if (txRaw)    espnTransactions = JSON.parse(txRaw) as EspnTransaction[];
    console.log('[cw] articles loaded from KV:', allData.articles.length);
    console.log('[cw] transactions loaded from KV:', espnTransactions.length);
    // KV cache miss — worker may not have run yet; fetch directly as fallback
    if (espnTransactions.length === 0) {
      espnTransactions = await fetchTransactions();
      console.log('[cw] transactions fetched directly from ESPN:', espnTransactions.length);
    }
  }
} catch (e) {
  console.error('[cw] KV read error:', e);
}
const stats = liveStats ?? { ...TEAM_STATS, source: 'fallback' as const };
let { articles, breaking, lastRun } = data;

// Fall back to mock data if KV is empty
if (articles.length === 0) {
  articles = mockArticles;
  breaking = mockBreaking;
}
// ─────────────────────────────────────────────────────────────────────────────

// ── Game Day Detection ────────────────────────────────────────────────────────
const VALID_PHASES = new Set(['pregame', 'live', 'halftime', 'postgame']);
const forcePhase = Astro.url.searchParams.get('gameday') as GamePhase | null;
let gameDay: GameDayInfo | null = null;
if (forcePhase && VALID_PHASES.has(forcePhase)) {
  gameDay = getMockGame(forcePhase);
} else {
  try { gameDay = await detectGameDay(); } catch {}
}

// ── Draft Day Detection ───────────────────────────────────────────────────────
const VALID_DRAFT_STATES = new Set(['pre', 'active', 'post']);
const forceDraft = Astro.url.searchParams.get('draft') as DraftState | null;
let draftDay: DraftInfo | null = null;
if (forceDraft && VALID_DRAFT_STATES.has(forceDraft)) {
  draftDay = getMockDraft(forceDraft);
} else if (isDraftDay()) {
  try { draftDay = await fetchDraftData(); } catch {}
}

const leads       = articles.slice(0, SITE.leadCount);
const streamItems = articles.slice(SITE.leadCount, SITE.storyCount);

// ── Transaction Tracker ───────────────────────────────────────────────────────
function showTransactionTracker(): boolean {
  if (TRANSACTION_SEASON.override !== null) return TRANSACTION_SEASON.override;
  // Show during the configured date window
  const now = new Date();
  const inWindow =
    now >= new Date(TRANSACTION_SEASON.start) &&
    now <= new Date(TRANSACTION_SEASON.end);
  if (inWindow) return true;
  // Outside window: show if there's been recent activity (mid-season trades)
  const windowMs = TRANSACTION_SEASON.activityWindowDays * 24 * 60 * 60 * 1000;
  const SHOW_TYPES = new Set(['signing', 'release', 'trade']);
  const recentCount = espnTransactions.filter(
    t => SHOW_TYPES.has(t.type) &&
         Date.now() - new Date(t.date).getTime() < windowMs
  ).length;
  return recentCount >= TRANSACTION_SEASON.activityThreshold;
}

const showTxTracker = showTransactionTracker() && espnTransactions.length > 0;

// Only show breaking ticker for items detected within the last 2 hours.
const BREAKING_TTL_MS = 2 * 60 * 60 * 1000;
const freshBreaking = breaking.filter(
  b => Date.now() - new Date(b.detectedAt).getTime() < BREAKING_TTL_MS
);
const hasBreaking = freshBreaking.length > 0;
const lastUpdated = lastRun?.completedAt ?? null;
